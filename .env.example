CONTABO_S3_ENDPOINT=https://eu2.contabostorage.com
CONTABO_S3_ACCESS_KEY=
CONTABO_S3_SECRET_KEY=
CONTABO_S3_CONTENT_BUCKET=rbx-content

# AI Chat — routes through the RBX LLM gateway (LiteLLM, Thalamus-governed).
# Sovereign path: site holds only a gateway virtual key; provider keys live in the gateway.
# LLM_GATEWAY_URL must include the OpenAI base path suffix (e.g. .../v1).
LLM_GATEWAY_URL=
LLM_GATEWAY_KEY=
LLM_MODEL=llama-3.3-70b-versatile

# Local-dev fallback only — direct provider, used when the gateway is unset.
GROQ_API_KEY=
