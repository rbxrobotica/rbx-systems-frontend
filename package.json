{
  "name": "rbx-site-sveltekit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "start": "node build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "seo-check": "node scripts/seo-check.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@sveltejs/kit": "^2.5.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@types/js-yaml": "^4.0.0",
    "@types/node": "^20.11.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-svelte": "^2.35.0",
    "globals": "^15.0.0",
    "prettier": "^3.2.0",
    "prettier-plugin-svelte": "^3.2.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1016.0",
    "@sveltejs/adapter-node": "^5.5.7",
    "altcha": "^3.1.0",
    "js-yaml": "^4.2.0",
    "marked": "^18.0.5",
    "svelte-i18n": "^4.0.0"
  },
  "pnpm": {
    "overrides": {
      "cookie": "^0.7.0",
      "esbuild": "^0.25.0"
    }
  }
}
